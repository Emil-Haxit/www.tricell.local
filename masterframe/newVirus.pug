style.
  .form-group {
    display: flex;
    align-items: center;
    margin-bottom: 12px;
    gap: 12px;
  }

  .form-group label {
    width: 220px;
    font-weight: 600;
  }

  .form-group input,
  .form-group textarea {
    flex: 1;
  }

form.add-new-research-object(
  action=`http://localhost:3000/api/newvirus/`
  method="POST"
  enctype="multipart/form-data"
  onsubmit="return virusForm()"
)
  .form-group
    label(for="number") Number
    input#number(type="text" name="number" )

  .form-group
    label(for="name") Name
    input#name(type="text" name="name")

  .form-group
    label(for="text") Text
    textarea#text(name="text")

  .form-group
    label(for="securityDataSheet") Security DataSheet
    input#securityDataSheet(type="file" name="securityDataSheet" )

  .form-group
    label(for="securityPresentationVideo") Security Presentation Video (YouTube link)
    input#securityPresentationVideo(type="text" name="securityPresentationVideo")

  .form-group
    label(for="securityHandlingVideo") Security Handling Video (YouTube link)
    input#securityHandlingVideo(type="text" name="securityHandlingVideo")

  button(type="submit") create

script(src="/scripts/virusform.js")